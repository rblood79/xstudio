  padding: 0px 0px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
}

.react-aria-ColorSwatch[data-variant="default"] {
  background: var(--bg);
  color: var(--fg);
  border-color: var(--border);

  &[data-hovered] {
    background: var(--bg-inset);
  }

  &[data-pressed] {
    background: var(--bg-overlay);
  }
}

.react-aria-ColorSwatch[data-variant="selected"] {
  background: var(--bg);
  color: var(--fg);
  border-color: var(--accent);

  &[data-hovered] {
    background: var(--bg-inset);
  }

  &[data-pressed] {
    background: var(--bg-overlay);
  }
}

.react-aria-ColorSwatch[data-size="sm"] {
  height: 20px;
  padding: 0px 0px;
  font-size: var(--text-xs);
  border-radius: var(--radius-sm);
}

.react-aria-ColorSwatch[data-size="md"] {
  height: 28px;
  padding: 0px 0px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
}

.react-aria-ColorSwatch[data-size="lg"] {
  height: 36px;
