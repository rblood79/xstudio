"/* ============================================================
 * AUTO-GENERATED from ToolbarSpec — DO NOT EDIT MANUALLY
 * Source: packages/specs/src/components/Toolbar.spec.ts
 * Archetype: default
 * ============================================================ */

@layer components {

.react-aria-Toolbar {
  /* Base styles — archetype: default */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: var(--font-sans);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    width: fit-content;

  /* Default size */
  font-size: var(--text-base);
  border-radius: var(--radius-md);
  gap: 8px;
}

.react-aria-Toolbar[data-size="sm"] {
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
  gap: 4px;
}

.react-aria-Toolbar[data-size="md"] {
  font-size: var(--text-base);
  border-radius: var(--radius-md);
  gap: 8px;
}

.react-aria-Toolbar[data-size="lg"] {
  font-size: var(--text-lg);
  border-radius: var(--radius-lg);
  gap: 10px;
}

.react-aria-Toolbar[data-focus-visible] {
  outline: var(--focus-ring-width) solid var(--focus-ring);
  outline-offset: var(--focus-ring-offset);
}

.react-aria-Toolbar[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

/* ── Tier 2: Composite Delegation ── */

.react-aria-Toolbar[data-orientation="horizontal"] {
  flex-direction: row;
}

.react-aria-Toolbar[data-orientation="vertical"] {
  flex-direction: column;
  align-items: start;
}


@media (forced-colors: active) {
  .react-aria-Toolbar {
    forced-color-adjust: auto;
  }
}


  .react-aria-Toolbar .react-aria-Group {
    display: contents;
  }

  .react-aria-Toolbar .react-aria-ToggleButton {
    width: 32px;
  }

  .react-aria-Toolbar .react-aria-Separator {
    align-self: stretch;
    background-color: var(--bg-muted);
  }

  .react-aria-Toolbar .react-aria-Separator[aria-orientation="vertical"] {
    width: 1px;
    margin: 0px 10px;
  }

  .react-aria-Toolbar .react-aria-Separator:not([aria-orientation="vertical"]) {
    border: none;
    height: 1px;
    width: 100%;
    margin: 10px 0;
  }


} /* @layer components */"
`;

