  .react-aria-Button[data-variant="default"] {
    background: var(--overlay-background);
    color: var(--text-color);
    border-color: var(--border-color);

    &[data-hovered] {
      background: var(--color-neutral-200);
      border-color: var(--color-neutral-200);
    }

    &[data-pressed] {
      background: var(--color-neutral-200);
      border-color: var(--color-neutral-200);
    }
  }

  .react-aria-Button[data-variant="primary"] {
    background: var(--highlight-background);
    color: var(--highlight-foreground);
    border-color: var(--highlight-background);

    &[data-hovered] {
      background: color-mix(in srgb, var(--highlight-background) 85%, black);
      border-color: color-mix(in srgb, var(--highlight-background) 85%, black);
    }

    &[data-pressed] {
      background: var(--highlight-background-pressed);
      border-color: var(--highlight-background-pressed);
    }
  }

  .react-aria-Button[data-variant="secondary"] {
    background: var(--button-background);
    color: var(--color-white);
    border-color: var(--button-background);

    &[data-hovered] {
      background: color-mix(in srgb, var(--button-background) 85%, black);
      border-color: color-mix(in srgb, var(--button-background) 85%, black);
    }

    &[data-pressed] {
      background: color-mix(in srgb, var(--button-background) 75%, black);
      border-color: color-mix(in srgb, var(--button-background) 75%, black);
    }
  }

  .react-aria-Button[data-variant="tertiary"] {
    background: var(--color-purple-600);
    color: var(--color-white);
    border-color: var(--color-purple-600);

    &[data-hovered] {
      background: color-mix(in srgb, var(--color-purple-600) 85%, black);
      border-color: color-mix(in srgb, var(--color-purple-600) 85%, black);
    }

    &[data-pressed] {
      background: color-mix(in srgb, var(--color-purple-600) 75%, black);
      border-color: color-mix(in srgb, var(--color-purple-600) 75%, black);
    }
  }

  .react-aria-Button[data-variant="error"] {
    background: var(--invalid-color);
    color: var(--color-white);
    border-color: var(--invalid-color);

    &[data-hovered] {
      background: color-mix(in srgb, var(--invalid-color) 85%, black);
      border-color: color-mix(in srgb, var(--invalid-color) 85%, black);
    }

    &[data-pressed] {
      background: color-mix(in srgb, var(--invalid-color) 75%, black);
      border-color: color-mix(in srgb, var(--invalid-color) 75%, black);
    }
  }

  .react-aria-Button[data-variant="surface"] {
    background: var(--color-neutral-200);
    color: var(--text-color);
    border-color: var(--border-color);

    &[data-hovered] {
      background: var(--color-neutral-200);
      border-color: var(--color-neutral-200);
    }

    &[data-pressed] {
      background: var(--color-neutral-200);
      border-color: var(--color-neutral-200);
    }
  }

  .react-aria-Button[data-variant="outline"] {
    background: var(--color-white);
    color: var(--highlight-background);
    border-color: var(--border-color-hover);
