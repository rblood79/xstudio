"/* ============================================================
 * AUTO-GENERATED from ToastSpec — DO NOT EDIT MANUALLY
 * Source: packages/specs/src/components/Toast.spec.ts
 * Archetype: overlay
 * ============================================================ */

@layer components {

.react-aria-Toast {
  /* Base styles — archetype: overlay */
    position: fixed;
    box-sizing: border-box;

  /* Default variant */
  background: var(--bg-muted);
  color: var(--fg);
  border: 1px solid var(--border);

  /* Default size */
  height: 48px;
  padding: 12px 16px;
  font-size: var(--text-base);
  border-radius: var(--radius-md);
  gap: 10px;
  --icon-size: 20px;
}

.react-aria-Toast[data-variant="info"] {
  background: var(--bg-muted);
  color: var(--fg);
  border-color: var(--border);

  &[data-hovered] {
    background: var(--bg-muted);
  }

  &[data-pressed] {
    background: var(--bg-muted);
  }
}

.react-aria-Toast[data-variant="positive"] {
  background: var(--color-green-100);
  color: var(--fg);
  border-color: var(--color-green-600);

  &[data-hovered] {
    background: var(--color-green-100);
  }

  &[data-pressed] {
    background: var(--color-green-100);
  }
}

.react-aria-Toast[data-variant="neutral"] {
  background: var(--bg-muted);
  color: var(--fg);
  border-color: var(--border);

  &[data-hovered] {
    background: var(--bg-muted);
  }

  &[data-pressed] {
    background: var(--bg-muted);
  }
}

.react-aria-Toast[data-variant="negative"] {
  background: var(--color-purple-100);
  color: var(--fg);
  border-color: var(--color-purple-600);

  &[data-hovered] {
    background: var(--color-purple-100);
  }

  &[data-pressed] {
    background: var(--color-purple-100);
  }
}

.react-aria-Toast[data-size="sm"] {
  height: 40px;
  padding: 8px 12px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
  gap: 8px;
  --icon-size: 16px;
}

.react-aria-Toast[data-size="md"] {
  height: 48px;
  padding: 12px 16px;
  font-size: var(--text-base);
  border-radius: var(--radius-md);
  gap: 10px;
  --icon-size: 20px;
}

.react-aria-Toast[data-size="lg"] {
  height: 56px;
  padding: 16px 20px;
  font-size: var(--text-lg);
  border-radius: var(--radius-lg);
  gap: 12px;
  --icon-size: 24px;
}

.react-aria-Toast[data-focus-visible] {
  outline: var(--focus-ring-width) solid var(--focus-ring);
  outline-offset: var(--focus-ring-offset);
}

.react-aria-Toast[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

@media (forced-colors: active) {
  .react-aria-Toast {
    forced-color-adjust: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  .react-aria-Toast {
    transition-duration: 0s !important;
  }
}

} /* @layer components */"
`;

exports[`CSSGenerator snapshot baseline > ToggleButton 1`] = `
"/* ============================================================
 * AUTO-GENERATED from ToggleButtonSpec — DO NOT EDIT MANUALLY
 * Source: packages/specs/src/components/ToggleButton.spec.ts
 * Archetype: button
 * ============================================================ */

@layer components {

.react-aria-ToggleButton {
  /* Base styles — archetype: button */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    box-sizing: border-box;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: var(--font-sans);

  /* Container styles (ADR-071 + ADR-083 Phase 1) */
  width: fit-content;
  display: inline-flex;
  align-items: center;
  justify-content: center;

  /* Default variant */
  --button-color: var(--bg-muted);
  --button-text: var(--fg);
  --button-border: transparent;

  /* Default size */
  height: auto;
  padding: 4px 12px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
  line-height: 20px;
  border-width: 1px;
  gap: 8px;
}

.react-aria-ToggleButton[data-variant="default"] {
  --button-color: var(--bg-muted);
  --button-text: var(--fg);
  --button-border: transparent;


  &[data-selected] {
    --button-color: var(--fg);
    --button-text: var(--bg);
    --button-border: var(--fg);
  }

  &[data-emphasized][data-selected] {
    --button-color: var(--accent);
    --button-text: var(--fg-on-accent);
    --button-border: var(--accent);
  }
}

.react-aria-ToggleButton[data-icon-only] {
  padding: 0;
  aspect-ratio: 1;
}

.react-aria-ToggleButton[data-size="xs"] {
  height: auto;
  padding: 1px 4px;
  font-size: var(--text-2xs);
  border-radius: var(--radius-sm);
  line-height: 16px;
  border-width: 1px;
  gap: 4px;
}

.react-aria-ToggleButton[data-size="sm"] {
  height: auto;
  padding: 2px 8px;
  font-size: var(--text-xs);
  border-radius: var(--radius-sm);
  line-height: 16px;
  border-width: 1px;
  gap: 6px;
}

.react-aria-ToggleButton[data-size="md"] {
  height: auto;
  padding: 4px 12px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
  line-height: 20px;
  border-width: 1px;
  gap: 8px;
}

.react-aria-ToggleButton[data-size="lg"] {
  height: auto;
  padding: 8px 16px;
  font-size: var(--text-base);
  border-radius: var(--radius-lg);
  line-height: 24px;
  border-width: 1px;
  gap: 10px;
}

.react-aria-ToggleButton[data-size="xl"] {
  height: auto;
  padding: 12px 24px;
  font-size: var(--text-lg);
  border-radius: var(--radius-lg);
  line-height: 28px;
  border-width: 1px;
  gap: 12px;
}

.react-aria-ToggleButton[data-hovered] {
}

.react-aria-ToggleButton[data-focus-visible] {
  outline: var(--focus-ring-width) solid var(--focus-ring);
  outline-offset: var(--focus-ring-offset);
}

.react-aria-ToggleButton[data-pressed] {
  box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);
}

.react-aria-ToggleButton[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

@media (forced-colors: active) {
  .react-aria-ToggleButton {
    forced-color-adjust: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  .react-aria-ToggleButton {
    transition-duration: 0s !important;
  }
}

} /* @layer components */"
