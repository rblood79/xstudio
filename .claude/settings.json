{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(node scripts/:*)",
      "Bash(npx playwright:*)",
      "Bash(pnpm run check:*)",
      "Bash(pnpm run perf:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/type-check-gate.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== PreCompact Context Snapshot ==='; echo 'Project: XStudio NoCode Builder'; echo 'Key rules: no inline Tailwind (tv()), no any type, DirectContainer pattern, O(1) elementsMap lookup, history before state change'; echo 'Pipeline: Memory→Index→History→DB→Preview'; echo 'Engines: Taffy WASM (Flex/Grid/Block), CanvasKit/Skia (render), PixiJS (events)'"
          }
        ]
      }
    ]
  }
}
