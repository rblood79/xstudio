"/* ============================================================
 * AUTO-GENERATED from AvatarSpec — DO NOT EDIT MANUALLY
 * Source: packages/specs/src/components/Avatar.spec.ts
 * Archetype: simple
 * ============================================================ */

@layer components {

.react-aria-Avatar {
  /* Base styles — archetype: simple */
    display: inline-flex;
    align-items: center;
    box-sizing: border-box;

  /* Container styles (ADR-071 + ADR-083 Phase 1) */
  display: inline-flex;
  align-items: center;

  /* Default variant */
  background: var(--bg-muted);
  color: var(--fg);
  border: none;

  /* Default size */
  height: 32px;
  padding: 0px 0px;
  font-size: var(--text-sm);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-variant="default"] {
  background: var(--bg-muted);
  color: var(--fg);

  &[data-hovered] {
    background: var(--bg-muted);
  }

  &[data-pressed] {
    background: var(--bg-muted);
  }
}

.react-aria-Avatar[data-size="xs"] {
  height: 24px;
  padding: 0px 0px;
  font-size: var(--text-2xs);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-size="sm"] {
  height: 28px;
  padding: 0px 0px;
  font-size: var(--text-xs);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-size="md"] {
  height: 32px;
  padding: 0px 0px;
  font-size: var(--text-sm);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-size="lg"] {
  height: 40px;
  padding: 0px 0px;
  font-size: var(--text-base);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-size="xl"] {
  height: 48px;
  padding: 0px 0px;
  font-size: var(--text-lg);
  border-radius: var(--radius-full);
}

.react-aria-Avatar[data-focus-visible] {
  outline: var(--focus-ring-width) solid var(--focus-ring);
  outline-offset: var(--focus-ring-offset);
}

.react-aria-Avatar[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

@media (forced-colors: active) {
  .react-aria-Avatar {
    forced-color-adjust: auto;
  }
}


} /* @layer components */"
`;

