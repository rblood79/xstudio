  outline-offset: var(--focus-ring-offset);
}

.react-aria-ColorSwatch[data-pressed] {
}

.react-aria-ColorSwatch[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

@media (forced-colors: active) {
  .react-aria-ColorSwatch {
    forced-color-adjust: auto;
  }
}


} /* @layer components */"
