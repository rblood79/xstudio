"/* ============================================================
 * AUTO-GENERATED from TooltipSpec — DO NOT EDIT MANUALLY
 * Source: packages/specs/src/components/Tooltip.spec.ts
 * Archetype: simple
 * ============================================================ */

@layer components {

.react-aria-Tooltip {
  /* Base styles — archetype: simple */
    display: inline-flex;
    align-items: center;
    box-sizing: border-box;

  /* Container styles (ADR-071 + ADR-083 Phase 1) */
  display: inline-flex;
  align-items: center;

  /* Default variant */
  background: var(--bg-muted);
  color: var(--fg);
  border: none;

  /* Default size */
  height: auto;
  padding: 6px 10px;
  font-size: var(--text-xs);
  border-radius: var(--radius-sm);
}

.react-aria-Tooltip[data-variant="neutral"] {
  background: var(--bg-muted);
  color: var(--fg);

  &[data-hovered] {
    background: var(--bg-muted);
  }

  &[data-pressed] {
    background: var(--bg-muted);
  }
}

.react-aria-Tooltip[data-variant="info"] {
  background: var(--color-info-100);
  color: var(--fg);

  &[data-hovered] {
    background: var(--color-info-100);
  }

  &[data-pressed] {
    background: var(--color-info-100);
  }
}

.react-aria-Tooltip[data-variant="positive"] {
  background: var(--color-green-100);
  color: var(--fg);

  &[data-hovered] {
    background: var(--color-green-100);
  }

  &[data-pressed] {
    background: var(--color-green-100);
  }
}

.react-aria-Tooltip[data-variant="negative"] {
  background: var(--color-error-100);
  color: var(--fg);

  &[data-hovered] {
    background: var(--color-error-100);
  }

  &[data-pressed] {
    background: var(--color-error-100);
  }
}

.react-aria-Tooltip[data-size="sm"] {
  height: auto;
  padding: 4px 8px;
  font-size: var(--text-xs);
  border-radius: var(--radius-sm);
}

.react-aria-Tooltip[data-size="md"] {
  height: auto;
  padding: 6px 10px;
  font-size: var(--text-xs);
  border-radius: var(--radius-sm);
}

.react-aria-Tooltip[data-size="lg"] {
  height: auto;
  padding: 8px 12px;
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
}

.react-aria-Tooltip[data-focus-visible] {
  outline: var(--focus-ring-width) solid var(--focus-ring);
  outline-offset: var(--focus-ring-offset);
}

.react-aria-Tooltip[data-disabled] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

@media (forced-colors: active) {
  .react-aria-Tooltip {
    forced-color-adjust: auto;
  }
}


} /* @layer components */"
