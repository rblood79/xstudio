{
  "name": "@composition/builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:preview": "vite build --config vite.preview.config.ts",
    "build:all": "pnpm run build:preview && pnpm run build",
    "lint": "eslint src/",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:pixi-plan": "node scripts/check-pixi-component-plan.mjs",
    "fix:pixi-plan": "node scripts/check-pixi-component-plan.mjs --write",
    "wasm:build": "wasm-pack build src/builder/workspace/canvas/wasm --target bundler --out-dir ../../../../../wasm-bindings/pkg",
    "clean": "rm -rf dist node_modules/.vite"
  },
