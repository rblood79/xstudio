}

.react-aria-DateRangePicker[data-size="xl"] .react-aria-Button {
  --drp-btn-width: var(--text-3xl);
  --drp-btn-height: var(--text-3xl);
}

.react-aria-DateRangePicker .react-aria-Button {
  background: transparent;
  color: var(--fg-muted);
  forced-color-adjust: none;
  border: none;
