}

/* ── Tier 2: Composite Delegation ── */

.react-aria-ProgressBar[data-variant="default"] {
  --fill-color: var(--accent);
  --track-color: var(--accent-subtle);
}

.react-aria-ProgressBar[data-variant="accent"] {
  --fill-color: var(--accent);
