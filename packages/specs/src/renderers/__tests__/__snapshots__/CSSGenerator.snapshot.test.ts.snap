}

.react-aria-ProgressBar[data-variant="neutral"] {
  --fill-color: var(--fg-muted);
  --track-color: var(--bg-muted);
}

.react-aria-ProgressBar[data-indeterminate="true"] .fill {
  width: 120px;
  border-radius: inherit;
  animation: ProgressBar-indeterminate 1.5s infinite ease-in-out;
  will-change: transform;
}

.react-aria-ProgressBar[data-disabled="true"] {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

.react-aria-ProgressBar[data-size="sm"] {
  --label-font-size: var(--text-xs);
}

.react-aria-ProgressBar[data-size="md"] {
  --label-font-size: var(--text-sm);
}

.react-aria-ProgressBar[data-size="lg"] {
  --label-font-size: var(--text-base);
}

.react-aria-ProgressBar[data-size="xl"] {
  --label-font-size: var(--text-lg);
}


@media (forced-colors: active) {
  .react-aria-ProgressBar {
    forced-color-adjust: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
