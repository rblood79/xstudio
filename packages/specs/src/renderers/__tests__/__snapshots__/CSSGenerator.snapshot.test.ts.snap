    transition-duration: 0s !important;
  }
}

  .react-aria-ProgressBar .react-aria-Label {
    grid-area: label;
    white-space: nowrap;
  }

  .react-aria-ProgressBar .value {
    grid-area: value;
    font-size: var(--text-sm);
    color: var(--fg-muted);
    white-space: nowrap;
  }

  .react-aria-ProgressBar .bar {
    grid-area: bar;
    box-shadow: var(--inset-shadow-xs);
    forced-color-adjust: none;
    height: var(--spacing-sm);
    border-radius: var(--radius-sm);
    overflow: hidden;
    will-change: transform;
    background: var(--track-color);
  }

  .react-aria-ProgressBar .fill {
    border-radius: var(--radius-sm);
    background: var(--fill-color);
    height: 100%;
    transition: width 200ms ease-out;
  }


  .react-aria-ProgressBar[data-size="sm"] .bar {
    height: var(--spacing-xs);
    border-radius: var(--radius-sm);
  }

  .react-aria-ProgressBar[data-size="sm"] .fill {
    border-radius: var(--radius-sm);
  }

  .react-aria-ProgressBar[data-size="sm"] .value {
    font-size: var(--text-xs);
  }

  .react-aria-ProgressBar[data-size="md"] .bar {
    height: var(--spacing-sm);
    border-radius: var(--radius-sm);
  }

  .react-aria-ProgressBar[data-size="md"] .fill {
    border-radius: var(--radius-sm);
  }

  .react-aria-ProgressBar[data-size="md"] .value {
    font-size: var(--text-sm);
  }

  .react-aria-ProgressBar[data-size="lg"] .bar {
    height: var(--spacing-md);
    border-radius: var(--radius-lg);
  }

  .react-aria-ProgressBar[data-size="lg"] .fill {
    border-radius: var(--radius-md);
  }

  .react-aria-ProgressBar[data-size="lg"] .value {
    font-size: var(--text-base);
  }

  .react-aria-ProgressBar[data-size="xl"] .bar {
    height: var(--spacing-lg);
    border-radius: var(--radius-lg);
  }

  .react-aria-ProgressBar[data-size="xl"] .fill {
    border-radius: var(--radius-lg);
  }

  .react-aria-ProgressBar[data-size="xl"] .value {
    font-size: var(--text-lg);
  }


} /* @layer components */

@keyframes ProgressBar-indeterminate {
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(250px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .react-aria-ProgressBar {
    transition-duration: 0s;
  }
}
"
