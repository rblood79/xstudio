  overflow: hidden;
}

.react-aria-Select .react-aria-SelectValue:where([data-placeholder]) {
  font-style: normal;
  color: var(--fg-muted);
  opacity: 0.6;
}

.react-aria-Select .react-aria-SelectValue [slot="description"] {
  display: none;
}

.react-aria-Select[data-size="xs"] .select-chevron {
  --select-chevron-size: 14px;
  --select-chevron-margin: var(--spacing-xs);
}

.react-aria-Select[data-size="sm"] .select-chevron {
  --select-chevron-size: 16px;
  --select-chevron-margin: var(--spacing-sm);
}

.react-aria-Select[data-size="md"] .select-chevron {
  --select-chevron-size: 18px;
  --select-chevron-margin: var(--spacing);
}

.react-aria-Select[data-size="lg"] .select-chevron {
  --select-chevron-size: 22px;
  --select-chevron-margin: var(--spacing-md);
}

.react-aria-Select[data-size="xl"] .select-chevron {
  --select-chevron-size: 28px;
  --select-chevron-margin: var(--spacing-lg);
}

.react-aria-Select .select-chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--select-chevron-size);
  height: var(--select-chevron-size);
  margin-left: var(--select-chevron-margin);
  border-radius: var(--radius-xs);
  background: var(--bg-overlay);
  color: var(--fg);
  transition: all 150ms ease;
  forced-color-adjust: none;
  box-shadow: var(--shadow-sm);
}

.react-aria-Select[data-size="xs"] .react-aria-FieldError {
  --select-hint-size: var(--text-2xs);
}

.react-aria-Select[data-size="sm"] .react-aria-FieldError {
  --select-hint-size: var(--text-2xs);
}

.react-aria-Select[data-size="md"] .react-aria-FieldError {
  --select-hint-size: var(--text-xs);
}

.react-aria-Select[data-size="lg"] .react-aria-FieldError {
  --select-hint-size: var(--text-sm);
}

.react-aria-Select[data-size="xl"] .react-aria-FieldError {
  --select-hint-size: var(--text-base);
}

.react-aria-Select .react-aria-FieldError {
  --error-font-size: var(--select-hint-size);
  --error-margin: var(--spacing-xs);
}

.react-aria-Select [slot="description"] {
  font-size: var(--select-hint-size);
  color: var(--fg-muted);
}

.react-aria-Popover[data-trigger="Select"] {
  min-width: var(--trigger-width);
  max-height: 300px;
  overflow: auto;
  border: 1px solid var(--border);
  border-radius: var(--border-radius);
  background: var(--bg-raised);
  box-shadow: var(--shadow-lg);
  contain: layout style;
}

.react-aria-Popover[data-trigger="Select"] .react-aria-ListBox {
  border: none;
  background: transparent;
  max-height: none;
  min-height: 24px;
}

.react-aria-Select[data-label-position="side"] {
  flex-direction: row;
  align-items: flex-start;
}

.react-aria-Select[data-disabled="true"] .react-aria-Button {
  background: color-mix(in srgb, var(--fg) 4%, transparent);
  border-color: color-mix(in srgb, var(--fg) 12%, transparent);
  color: color-mix(in srgb, var(--fg) 38%, transparent);
  cursor: not-allowed;
  opacity: 0.38;
}

.react-aria-Select[data-disabled="true"] .react-aria-Button .select-chevron {
  background: color-mix(in srgb, var(--fg) 12%, transparent);
  color: color-mix(in srgb, var(--fg) 38%, transparent);
}

.react-aria-Select[data-quiet="true"] .react-aria-Button {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-radius: 0;
  border-bottom: 1px solid var(--border);
}

.react-aria-Select[data-quiet="true"] .react-aria-Button[data-hovered]:not([data-pressed]):not([data-disabled]) {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-bottom-color: var(--border-hover);
}

.react-aria-Select[data-quiet="true"] .react-aria-Button[data-focus-visible]:not([data-disabled]) {
  outline: none;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-bottom-color: var(--accent);
}

.react-aria-Select[data-quiet="true"] .react-aria-Button[data-focused]:not([data-disabled]) {
  outline: none;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-bottom-color: var(--accent);
}

.react-aria-Select[data-quiet="true"] .react-aria-Button[data-pressed]:not([data-disabled]) {
  outline: none;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
  border-bottom-color: var(--accent);
}

.react-aria-Select[data-quiet="true"][data-invalid] .react-aria-Button {
  border-color: transparent;
  border-bottom-color: var(--negative);
}


@media (forced-colors: active) {
  .react-aria-Select {
    forced-color-adjust: auto;
  }
}


} /* @layer components */"
`;

